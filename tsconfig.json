{
  "extends": "@tsconfig/node-lts/tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist/",
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "lib": ["DOM"],
    "moduleResolution": "bundler",
    "module": "esnext"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"],
}